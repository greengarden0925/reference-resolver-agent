# 每日新聞播報設定

# 研究主題 (英文，逗號分隔，用於 PubMed 搜尋)
RESEARCH_TOPICS=artificial intelligence medicine,machine learning clinical,large language model healthcare,natural language processing biomedical,clinical decision support

# 時區
TIMEZONE=Asia/Taipei

# 每日自動擷取時間 (24小時制)
DAILY_HOUR=9
DAILY_MINUTE=0

# 每類別最多顯示幾則新聞
MAX_NEWS_PER_CATEGORY=5

# 學術論文最多顯示幾篇
MAX_ACADEMIC_PAPERS=8

# (選填) OpenAI API Key — 用於產生高品質 TTS 音頻
# 若不填入，將使用瀏覽器內建 Web Speech API
OPENAI_API_KEY=

# 資料庫路徑
DATABASE_PATH=podcast.db
